{
  "name": "concordia-client",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build-typescript": "tsc",
    "watch-typescript": "tsc --watch",
    "watch-electron": "nodemon --watch dist --exec electron ./dist/main.js",
    "dev": "concurrently \"pnpm watch-typescript\" \"pnpm watch-electron\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.25.0",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "nodemon": "^3.1.14"
  },
  "dependencies": {
    "electron-reload": "2.0.0-alpha.1",
    "express": "^5.2.1",
    "typescript": "^5.9.3"
  },
  "build": {
    "asar": false,
    "appId": "com.reitech.concordia",
    "files": [
      "dist/main.js",
      "dist/preload.js",
      {
        "from": "dist/build",
        "to": "dist/build",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "dist/utils",
        "to": "dist/utils",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    }
  }
}
